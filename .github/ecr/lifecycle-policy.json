{
  "rules": [
    {
      "rulePriority": 1,
      "description": "Keep only the most recent 3 images to avoid unbounded ECR storage growth",
      "selection": {
        "tagStatus": "any",
        "countType": "imageCountMoreThan",
        "countNumber": 3
      },
      "action": {
        "type": "expire"
      }
    }
  ]
}
